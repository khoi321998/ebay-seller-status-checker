{
    "$schema": "https://apify.com/schemas/v1/input.ide.json",
    "title": "eBay Seller Active Checker",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "sellerUrls": {
            "title": "Seller URLs",
            "type": "array",
            "description": "eBay seller store URLs to check, e.g. https://www.ebay.com/str/ronronnerxxm",
            "editor": "stringList",
            "prefill": [
                "https://www.ebay.com/str/ronronnerxxm",
                "https://www.ebay.com/str/bbazqzv"
            ]
        },
        "maxConcurrency": {
            "title": "Max Concurrency",
            "type": "integer",
            "description": "Maximum parallel checks. Keep low to avoid eBay anti-bot.",
            "default": 5,
            "minimum": 1,
            "maximum": 20
        }
    },
    "required": ["sellerUrls"]
}
